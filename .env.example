# ══════════════════════════════════════════════════════════════════════════════
# PulseEarth — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Anthropic Claude (REQUIRED) ───────────────────────────────────────────────
# Powers: Brief Me, AI Anchor, Investment Report, AI Insight Stream
# Model used: claude-haiku-4-5-20251001
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS DynamoDB (REQUIRED) ───────────────────────────────────────────────────
# Stores city metrics (29 global economic hubs)
# Must create the table before running `npm run seed`
# IAM permissions needed: dynamodb:PutItem, GetItem, Scan, Query

# AWS region where your DynamoDB table lives
AWS_REGION=us-east-1

# IAM access key with DynamoDB permissions
AWS_ACCESS_KEY_ID=AKIA...

# IAM secret key
AWS_SECRET_ACCESS_KEY=...

# DynamoDB table name (create this manually or via CloudFormation)
# Partition key: cityId (String)
DYNAMODB_TABLE_NAME=city-metrics

# ── App URL (RECOMMENDED) ─────────────────────────────────────────────────────
# Used for canonical links and OpenGraph metadata
# In development: http://localhost:3000
# In production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google AI / Gemini Flash (OPTIONAL) ──────────────────────────────────────
# Alternative model for investment report generation
# If absent, Claude Haiku handles all AI tasks
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── HuggingFace (OPTIONAL) ────────────────────────────────────────────────────
# Enables TTS audio in the AI Anchor widget
# Models: Kokoro TTS or Parler TTS (attempted in order)
# Without this key, AI Anchor shows text-only (no audio) — all other features work
# Get your token: https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=hf_...

# ── Cron / Scheduled Jobs (OPTIONAL) ─────────────────────────────────────────
# Secret for authenticating scheduled data-refresh requests
# Set this if you configure Vercel Cron or an external scheduler
CRON_SECRET=your-cron-secret-here

# ── Notes ─────────────────────────────────────────────────────────────────────
# World Bank API: Free, no auth required. PulseEarth calls it directly.
# RSS Feeds: Free, no auth required. BBC, Reuters, Google News, country-specific.
# NaturalEarth GeoJSON: Served from CloudFront CDN, no auth required.
# react-globe.gl textures: Served from jsDelivr CDN, no auth required.
